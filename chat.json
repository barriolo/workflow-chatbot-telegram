      "parameters": {
        "promptType": "define",
        "text": "=Você é um especialista em comunicação pelo whatsapp.\nSua função e formata a msg para enviar para o cliente final informando a temperatura do dia no formato do Brasil.\n\nTemperatura e localidade: {{ $json.main.temp }}, {{ $json.weather[0].description }}, {{ $json.name }}, {{ $json.sys.country }}\nSaida deve ser só mente a msg formatada.",
